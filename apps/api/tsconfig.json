{
  "compilerOptions": {
    "lib": ["ESNext"],
    "target": "ESNext",
    "module": "Preserve",
    "moduleDetection": "force",
    "jsx": "react-jsx",
    "allowJs": true,

    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,

    "strict": true,
    "skipLibCheck": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,

    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noPropertyAccessFromIndexSignature": false,

    "paths": {
      "@assets": ["./src/assets"],
      "@assets/*": ["./src/assets/*"],

      "@db": ["./src/db"],
      "@db/*": ["./src/db/*"],

      "@lib": ["./src/lib"],
      "@lib/*": ["./src/lib/*"],

      "@models": ["./src/models"],
      "@models/*": ["./src/models/*"],

      "@routes": ["./src/routes"],
      "@routes/*": ["./src/routes/*"],

      "@services": ["./src/services"],
      "@services/*": ["./src/services/*"],

      "@utils": ["./src/utils"],
      "@utils/*": ["./src/utils/*"]
    }
  }
}
